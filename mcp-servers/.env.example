# Environment variables for MCP servers
# Copy this file to .env and fill in your API keys

# Shodan API Key
# Get yours at: https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key

# Censys API Credentials  
# Get yours at: https://censys.io/account/api
CENSYS_API_ID=your_censys_api_id
CENSYS_API_SECRET=your_censys_api_secret

# NVD API Key (optional, for higher rate limits)
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key

# Burp Suite Professional REST API
# Enable in Burp: Extender > REST API > Enable
BURP_API_URL=http://127.0.0.1:8080

# GitHub Token (for GitHub MCP)
GITHUB_TOKEN=your_github_token

# AWS Credentials (for AWS MCP)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
